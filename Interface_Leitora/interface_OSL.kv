#:kivy 1.11.1
#:import dp kivy.metrics.dp

ScreenManager:
    TelaPrincipalLeitora:
    TelaParametrosLeitura:
    TelaGraficos:


<TelaPrincipalLeitora>:
    name: "main"

    BoxLayout:
        orientation: "horizontal"
        padding: 2
        spacing: 2

        BoxLayout:
            orientation: "vertical"
            padding: 8
            spacing: 8

            Label:
                text: "Interface OSL"
                size_hint_y: None
                height: 34
                font_size: "22sp"
                bold: True

            BoxLayout:
                size_hint_y: None
                height: "36dp"
                spacing: 8

                Spinner:
                    id: porta_spinner
                    text: "Porta"
                    values: []

                Button:
                    text: "Atualizar"
                    size_hint_x: None
                    width: "100dp"
                    on_release: app.root.get_screen("main").atualizar_portas_serial()

                Button:
                    id: botao_conexao_serial
                    text: "Conectar"
                    size_hint_x: None
                    width: "110dp"
                    on_release: app.root.get_screen("main").func_botao_conexao_serial()

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                TextInput:
                    id: nome_arquivo_input
                    hint_text: "Nome do arquivo"

                Button:
                    id: botao_log
                    text: "Iniciar Log"
                    on_release: app.root.get_screen("main").func_botao_log()

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                Label:
                    text: "ecc"
                    text_size: self.size
                    font_size: "18sp"
                    halign: "center"
                    valign: "middle"

                TextInput:
                    id: ecc_textInput
                    hint_text: "ecc"

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                Label:
                    text: "rcf"
                    text_size: self.size
                    font_size: "18sp"
                    halign: "center"
                    valign: "middle"

                TextInput:
                    id: rcf_textInput
                    hint_text: "rcf"

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                Label:
                    text: "branco"
                    text_size: self.size
                    font_size: "18sp"
                    halign: "center"
                    valign: "middle"

                TextInput:
                    id: branco_textInput
                    hint_text: "branco"

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                Label:
                    text: "fcal"
                    text_size: self.size
                    font_size: "18sp"
                    halign: "center"
                    valign: "middle"

                TextInput:
                    id: fcal_textInput
                    hint_text: "fcal"

            BoxLayout:
                size_hint_y: None
                height: "36dp"

                Label:
                    text: "fenerg"
                    text_size: self.size
                    font_size: "18sp"
                    halign: "center"
                    valign: "middle"

                TextInput:
                    id: fenerg_textInput
                    hint_text: "fenerg"

            GridLayout:



                cols: 2
                size_hint_y: None
                height: 108
                spacing: 8

                Button:
                    text: "SUDO leitura"
                    on_release: app.root.get_screen("main").botao_leitura()

                Button:
                    text: "SUDO stop"
                    on_release: app.root.get_screen("main").enviar_comando_sudo("stop")

                Button:
                    text: "SUDO zerar"
                    on_release: app.root.get_screen("main").enviar_comando_sudo("zerar")

                Button:
                    text: "SUDO ligaLed"
                    on_release: app.root.get_screen("main").enviar_comando_sudo("liga_led")

            Button:
                text: "Graficos"
                size_hint_y: None
                height: "36dp"
                on_release: app.root.current = "graficos"

            Label:
                id: status_label
                text: "Conectando serial..."
                size_hint_y: None
                height: 32
                text_size: self.size
                halign: "left"
                valign: "middle"

            Label:
                id: recebido_label
                text: "Recebido: ---"
                text_size: self.size
                halign: "left"
                valign: "top"

        BotaoNavegacaoParametros:
            text: ""
            size_hint_x: None
            width: "45dp"

            font_size: "22sp"
            bold: True

            background_normal: ""
            background_down: ""
            background_color: 0.18, 0.18, 0.18, 1

            color: 1, 1, 1, 1
            canvas.after:
                Color:
                    rgba: 1, 1, 1, 1
                Rectangle:
                    source: "assets/UI/angulo-direito-branco.png"
                    size: dp(18), dp(18)
                    pos: self.center_x - dp(9), self.center_y - dp(9)

            on_release: app.root.current = "parametros"

<TelaParametrosLeitura>:
    name: "parametros"

    BoxLayout:
        orientation: "vertical"
        padding: 12
        spacing: 12

        Label:
            text: "Parametros"
            size_hint_y: None
            height: 40
            font_size: "22sp"
            bold: True

        GridLayout:
            cols: 2
            spacing: 8
            row_default_height: 42
            row_force_default: True
            size_hint_y: None
            height: self.minimum_height

            Label:
                text: "M modo"
            TextInput:
                id: modo_input
                text: "1"
                multiline: False
                input_filter: "int"

            Label:
                text: "G ganho"
            TextInput:
                id: ganho_input
                text: "3"
                multiline: False
                input_filter: "int"

            Label:
                text: "L tempo leitura"
            TextInput:
                id: tempo_leitura_input
                text: "03000"
                multiline: False
                input_filter: "int"

            Label:
                text: "P potencia"
            TextInput:
                id: potencia_input
                text: "4"
                multiline: False
                input_filter: "int"

            Label:
                text: "Z tempo zeramento"
            TextInput:
                id: tempo_zeramento_input
                text: "05000"
                multiline: False
                input_filter: "int"

            Label:
                text: "Q potencia zeramento"
            TextInput:
                id: potencia_zeramento_input
                text: "2"
                multiline: False
                input_filter: "int"

        Button:
            text: "Enviar parametros"
            size_hint_y: None
            height: 48
            on_release: app.root.get_screen("main").enviar_parametros()

        Button:
            text: "Voltar"
            size_hint_y: None
            height: 48
            on_release: app.root.current = "main"

        Widget:


<TelaGraficos>:
    name: "graficos"

    BoxLayout:
        orientation: "horizontal"
        padding: 8
        spacing: 8

        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.4
            spacing: 8

            Label:
                text: "Arquivos de log"
                size_hint_y: None
                height: 30
                bold: True

            FileChooserListView:
                id: seletor_arquivo
                filters: ["*.txt", "*.csv"]
                on_selection: app.root.get_screen("graficos").selecionar_arquivo(self.selection)

        BoxLayout:
            orientation: "vertical"
            spacing: 8

            Label:
                text: "Grafico"
                size_hint_y: None
                height: 30
                font_size: "22sp"
                bold: True

            Image:
                id: imagem_grafico
                source: ""

            BoxLayout:
                size_hint_y: None
                height: "44dp"
                spacing: 8

                Button:
                    text: "Gerar grafico"
                    on_release: app.root.get_screen("graficos").gerar_grafico()

                Button:
                    text: "Exportar CSV"
                    on_release: app.root.get_screen("graficos").exportar_csv()

            Label:
                id: status_grafico_label
                text: "Selecione um arquivo de log."
                size_hint_y: None
                height: 32
                text_size: self.size
                halign: "left"
                valign: "middle"

            Button:
                text: "Voltar"
                size_hint_y: None
                height: 44
                on_release: app.root.current = "main"
